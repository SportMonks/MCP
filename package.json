{
  "name": "sportmonks-football-mcp-server",
  "version": "1.1.0",
  "description": "MCP server for Sportmonks Football API 3.0 with five focused tools for search, entity lookup, matches, match previews, and standings",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sportmonks-football-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "node ./node_modules/ts-node/dist/bin.js src/index.ts",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sportmonks",
    "football",
    "livescores",
    "fixtures",
    "standings",
    "ai",
    "claude",
    "cursor"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
